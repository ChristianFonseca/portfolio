# Copiar a .env y completar. NUNCA commitear .env.

# MailerSend (formulario de contacto)
MAILERSEND_API_KEY=

# Remitente del email de contacto. En producción debe ser un sender del
# dominio verificado en MailerSend (ej. no-reply@christianfonseca.dev).
# Si se omite, usa el dominio trial de MailerSend (solo entrega al owner de la cuenta).
CONTACT_FROM_EMAIL=

# Destinatario de los mensajes del formulario (default: christian.fonseca.r@gmail.com)
CONTACT_TO_EMAIL=
