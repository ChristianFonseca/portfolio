# Copiar a .env y completar. NUNCA commitear .env.

# MailerSend (formulario de contacto)
MAILERSEND_API_KEY=

# Remitente del email de contacto: sender del dominio verificado en MailerSend
# (ej. no-reply@christianfonseca.dev). Si se omite, usa el dominio trial de
# MailerSend (solo entrega al owner de la cuenta).
CONTACT_FROM_EMAIL=

# Destinatario de los mensajes del formulario (default: christian.fonseca.r@gmail.com)
CONTACT_TO_EMAIL=

# Postgres del contenido y usuarios del admin.
# En el VPS (red docker pg-shared): postgres://portfolio:<pass>@pg-dev:5432/portfolio
# En local via tunel SSH:           postgres://portfolio:<pass>@127.0.0.1:15432/portfolio
DATABASE_URL=

# Secreto para firmar la cookie de sesion del admin (64+ chars aleatorios)
SESSION_SECRET=

# API key de Gemini para la traduccion EN<->ES del contenido en el admin
# (https://aistudio.google.com/apikey). El modelo se elige en el admin (Configuracion).
GEMINI_API_KEY=
